{
  "name": "opencampus",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:migrate": "pnpm --filter @opencampus/api prisma migrate dev",
    "db:generate": "pnpm --filter @opencampus/api prisma generate",
    "db:push": "pnpm --filter @opencampus/api prisma db push"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "pnpm@9.15.0"
}
